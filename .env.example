# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenAI API Key (для генерации дерева анализа и других ответов)
# Получить: https://platform.openai.com/api-keys
# Без ключа бот работает, но дерево анализа будет шаблонным
LLM_API_KEY=sk-your_openai_api_key_here

# Опциональные настройки
DEBUG=True
LOG_LEVEL=INFO

# Email для запросов «Нужна помощь» (по умолчанию vershinina.katya@gmail.com)
# Для отправки настройте SMTP (Gmail: smtp.gmail.com, порт 587, App Password)
HELP_EMAIL=vershinina.katya@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# RAG (PostgreSQL + pgvector) — для обогащения аналитики материалами из базы знаний
# Требуется PostgreSQL с расширением pgvector: CREATE EXTENSION vector;
DATABASE_URL=postgresql://user:password@localhost:5432/preza_bot
RAG_ENABLED=false
RAG_TOP_K=5
