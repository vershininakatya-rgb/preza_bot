# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=your_bot_token_here

# OpenAI API Key (для генерации дерева анализа и других ответов)
# Получить: https://platform.openai.com/api-keys
# Без ключа бот работает, но дерево анализа будет шаблонным
LLM_API_KEY=sk-your_openai_api_key_here

# Опциональные настройки
DEBUG=True
LOG_LEVEL=INFO

# Куда приходят запросы «Нужна помощь» — ваш Telegram chat_id (число)
# Узнать: написать боту @userinfobot в Telegram
ADMIN_CHAT_ID=

# Chat ID чата для логов мониторинга (опционально). Если не задан — задаётся при /start в группе/канале
# LOG_CHAT_ID=

# БД (Supabase/PostgreSQL). Нужен для RAG и для сохранения данных бота (пользователи, аналитика, диаграммы, обратная связь)
# Требуется расширение pgvector для RAG: CREATE EXTENSION vector;
# Supabase: Project Settings → Database → Connection string (URI). См. docs/SUPABASE_SETUP.md
DATABASE_URL=postgresql://user:password@localhost:5432/preza_bot
RAG_ENABLED=false
RAG_TOP_K=5

# Сохранение данных бота в БД (пользователи, аналитика, диаграммы, «Нужна помощь»). По умолчанию true при заданном DATABASE_URL
# PERSIST_TO_DB=false — отключить запись в таблицы telegram_users, analyses, diagrams, feedback_requests
# PERSIST_TO_DB=true

# Supabase REST API (для сохранения данных бота через REST вместо прямого Postgres). Опционально.
# Если заданы — бот пишет в Supabase через REST; иначе используется DATABASE_URL (asyncpg).
# Взять: Supabase → Project Settings → API → Project URL и service_role key (secret)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
